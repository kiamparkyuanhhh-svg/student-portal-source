<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body>
<div class="shell">
  <%- include('../partials/sidebar', { active: 'courses' }) %>
  <div class="main">
    <div class="page-header">
      <div>
        <span class="eyebrow">Registrar</span>
        <h1>Manage Courses</h1>
        <p>Create, edit, and remove course offerings.</p>
      </div>
      <a href="/courses/new" class="btn btn-gold">+ Add course</a>
    </div>

    <%- include('../partials/flash') %>

    <form class="filter-bar" method="GET" action="/courses/manage">
      <input type="text" name="keyword" placeholder="Search by title or code..." value="<%= filters.keyword %>">
      <select name="department" onchange="this.form.submit()">
        <option value="">All departments</option>
        <% departments.forEach(function(d) { %>
          <option value="<%= d.department %>" <%= filters.department === d.department ? 'selected' : '' %>><%= d.department %></option>
        <% }) %>
      </select>
      <button class="btn btn-outline" type="submit">Search</button>
    </form>

    <div class="panel">
      <% if (courses.length === 0) { %>
        <div class="empty-state"><div class="icon">📚</div><p>No courses found.</p></div>
      <% } else { %>
        <table>
          <thead>
            <tr><th>Code</th><th>Title</th><th>Department</th><th>Credits</th><th>Capacity</th><th>Semester</th><th></th></tr>
          </thead>
          <tbody>
            <% courses.forEach(function(c) { %>
              <tr>
                <td><span class="code-tag"><%= c.code %></span></td>
                <td><%= c.title %></td>
                <td><%= c.department %></td>
                <td><%= c.credits %></td>
                <td><%= c.capacity %></td>
                <td><%= c.semester %></td>
                <td class="actions">
                  <a class="btn btn-outline btn-sm" href="/courses/<%= c.id %>/edit">Edit</a>
                  <form class="inline" action="/courses/<%= c.id %>?_method=DELETE" method="POST" onsubmit="return confirm('Delete this course? This also removes related enrollments.')">
                    <button class="btn btn-danger btn-sm" type="submit">Delete</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>
  </div>
</div>
</body>
</html>
