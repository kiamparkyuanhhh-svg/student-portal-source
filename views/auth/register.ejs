<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body>
  <div class="auth-wrap">
    <div class="auth-card">
      <div class="eyebrow">Meridian · Student Records</div>
      <h1>Create your account</h1>
      <p class="sub">Register to browse courses and manage your enrollments.</p>

      <%- include('../partials/flash') %>

      <form action="/auth/register" method="POST" novalidate>
        <div class="field">
          <label for="name">Full name</label>
          <input type="text" id="name" name="name" required minlength="2" placeholder="Alice Tan">
        </div>
        <div class="field-row">
          <div class="field">
            <label for="student_id">Student ID</label>
            <input type="text" id="student_id" name="student_id" required placeholder="S1004">
          </div>
          <div class="field">
            <label for="department">Department</label>
            <input type="text" id="department" name="department" required placeholder="Computer Science">
          </div>
        </div>
        <div class="field">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required placeholder="you@portal.edu">
        </div>
        <div class="field">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" required minlength="6" placeholder="At least 6 characters">
        </div>
        <button class="btn btn-primary" type="submit">Create account</button>
      </form>

      <div class="switch">Already have an account? <a href="/auth/login">Sign in</a></div>
    </div>
  </div>
</body>
</html>
